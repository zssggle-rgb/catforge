# CatForge runtime environment template.
# Copy this file to the target server as /opt/catforge/.env and replace placeholders there.

CATFORGE_ENV=dev

# API container runtime.
CATFORGE_DATABASE_URL=postgresql+psycopg://catforge_app:change-me@host.docker.internal:5432/catforge_dev
CATFORGE_REDIS_URL=redis://redis:6379/0
CATFORGE_UPLOAD_DIR=/data/uploads
CATFORGE_EXPORT_DIR=/data/exports
CATFORGE_SYNC_JOBS=true

# Published ports for the cloud compose file.
CATFORGE_API_PORT=8000
CATFORGE_WEB_PORT=5173

# Vite dev server proxy inside the cloud compose network.
VITE_PROXY_TARGET=http://api:8000

# Local deployment script settings. Keep real values in .catforge/deploy-*.env.
CATFORGE_DEPLOY_HOST=123.56.42.205
CATFORGE_DEPLOY_USER=deploy
CATFORGE_SSH_KEY=/path/to/HX-ECS.pem
CATFORGE_APP_DIR=/opt/catforge
CATFORGE_COMPOSE_FILE=docker-compose.cloud.yml
CATFORGE_RUNTIME_ENV_FILE=.catforge/server-a.runtime.env
CATFORGE_APP_URL=http://123.56.42.205:8000

# Deployment code sync. Use github for cloud dev/test environments so the
# server deploys the committed version instead of a local uncommitted tree.
CATFORGE_SYNC_STRATEGY=github
CATFORGE_GIT_REPO=https://github.com/zssggle-rgb/catforge.git
CATFORGE_GIT_REF=main
CATFORGE_GIT_DEPTH=1
CATFORGE_GIT_TIMEOUT=60
