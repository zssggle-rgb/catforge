# CatForge runtime environment template.
# Copy this file to the target server as /opt/catforge/.env and replace placeholders there.

CATFORGE_ENV=dev

# API container runtime.
CATFORGE_DATABASE_URL=postgresql+psycopg://catforge_app:change-me@host.docker.internal:5432/catforge_dev
CATFORGE_REDIS_URL=redis://redis:6379/0
CATFORGE_UPLOAD_DIR=/data/uploads
CATFORGE_EXPORT_DIR=/data/exports
CATFORGE_SYNC_JOBS=true

# Optional Feishu/Lark report publishing for XiaoAo analyst answers.
# The cloud compose file mounts these host-side lark-cli paths into the API
# container as /root/.lark-cli and /root/.local/share/lark-cli.
CATFORGE_ANALYST_REPORT_PUBLISHER=
CATFORGE_FEISHU_CLI_BIN=/opt/openclaw-node/bin/lark-cli
CATFORGE_FEISHU_AS=bot
CATFORGE_FEISHU_NODE_DIR=/home/deploy/.openclaw/tools/node
CATFORGE_FEISHU_CONFIG_DIR=/home/deploy/.lark-cli
CATFORGE_FEISHU_DATA_DIR=/home/deploy/.local/share/lark-cli
CATFORGE_FEISHU_LINK_SHARE_ENTITY=anyone_readable
CATFORGE_FEISHU_EXTERNAL_ACCESS=true
CATFORGE_FEISHU_SECURITY_ENTITY=anyone_can_view
CATFORGE_FEISHU_COMMENT_ENTITY=anyone_can_view
CATFORGE_FEISHU_SHARE_ENTITY=only_full_access
CATFORGE_FEISHU_INVITE_EXTERNAL=true

# Published ports for the cloud compose file.
CATFORGE_API_PORT=8000
CATFORGE_WEB_PORT=5173

# Vite dev server proxy inside the cloud compose network.
VITE_PROXY_TARGET=http://api:8000

# Local deployment script settings. Keep real values in .catforge/deploy-*.env.
CATFORGE_DEPLOY_HOST=123.56.42.205
CATFORGE_DEPLOY_USER=deploy
CATFORGE_SSH_KEY=/path/to/HX-ECS.pem
CATFORGE_APP_DIR=/opt/catforge
CATFORGE_COMPOSE_FILE=docker-compose.cloud.yml
CATFORGE_RUNTIME_ENV_FILE=.catforge/server-a.runtime.env
CATFORGE_APP_URL=http://123.56.42.205:8000

# Deployment code sync. Use github for cloud dev/test environments so the
# server deploys the committed version instead of a local uncommitted tree.
CATFORGE_SYNC_STRATEGY=github
CATFORGE_GIT_REPO=https://github.com/zssggle-rgb/catforge.git
CATFORGE_GIT_REF=main
CATFORGE_GIT_DEPTH=1
CATFORGE_GIT_TIMEOUT=60

# Fast 205 API hot-fix settings. Use scripts/sync-hotfix-205.sh for committed
# Python/API changes; it syncs the same Git revision, falls back to a local git
# bundle when 205 cannot reach GitHub, copies API source into the running
# container, and restarts only the API service.
CATFORGE_HOTFIX_PUSH=true
CATFORGE_HOTFIX_BUNDLE_FALLBACK=true
CATFORGE_HOTFIX_INSTALL_CLAUDE_SKILLS=true
CATFORGE_HOTFIX_RESTART_API=true
# Defaults to the current local branch. Set only when intentionally hot-fixing
# a different branch/ref.
CATFORGE_HOTFIX_GIT_REF=
# Optional command run inside the API container after readyz passes.
CATFORGE_HOTFIX_SMOKE_COMMAND=
