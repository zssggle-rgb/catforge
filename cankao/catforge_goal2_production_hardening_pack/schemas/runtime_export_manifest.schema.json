{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RuntimeExportManifest",
  "type": "object",
  "required": [
    "export_id",
    "asset_version",
    "files"
  ],
  "properties": {
    "export_id": {
      "type": "string"
    },
    "asset_version": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          }
        }
      }
    },
    "created_at": {
      "type": "string"
    }
  }
}
