{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MarketFactRow",
  "type": "object",
  "required": ["sku_code", "period", "period_type", "channel_group", "channel_type"],
  "properties": {
    "sku_code": {"type": "string", "minLength": 1},
    "period": {"type": "string", "minLength": 1},
    "period_type": {"type": "string", "enum": ["week", "month"]},
    "channel_group": {"type": "string", "minLength": 1},
    "channel_type": {"type": "string", "minLength": 1},
    "channel_name": {"type": ["string", "null"]},
    "sales_volume": {"type": ["number", "null"]},
    "sales_amount": {"type": ["number", "null"]},
    "avg_price": {"type": ["number", "null"]},
    "promotion_flag": {"type": ["boolean", "null"]}
  }
}
